# ──────────────────────────────────────────────────────────────
# mediasoup / RTC
# ──────────────────────────────────────────────────────────────
# Public IP advertised in ICE candidates (D-03). HARD-REQUIRED, no default —
# the service throws at boot if unset. Never auto-detect; set the droplet's
# public IPv4 here explicitly.
MEDIASOUP_ANNOUNCED_IP=
# Base UDP/TCP port for the per-worker WebRtcServer shared port.
RTC_BASE_PORT=44444

# ──────────────────────────────────────────────────────────────
# Signaling / admin secrets
# ──────────────────────────────────────────────────────────────
# Dev shared-secret gating the WS join (Phase-1 placeholder; Phase 2 swaps to HS256).
SFU_DEV_SECRET=
# Server-to-server secret gating the admin HTTP surface (X-Sfu-Secret).
SFU_ADMIN_SECRET=

# ──────────────────────────────────────────────────────────────
# coturn / TURN
# ──────────────────────────────────────────────────────────────
# Shared static-auth-secret for coturn HMAC credential minting. Must match
# coturn's static-auth-secret directive.
TURN_STATIC_AUTH_SECRET=
# Public hostname clients reach coturn on (e.g. turn.sideby.me).
TURN_PUBLIC_HOST=
# TTL (seconds) for minted TURN credentials.
TURN_CRED_TTL_SEC=3600

# ──────────────────────────────────────────────────────────────
# Room policy
# ──────────────────────────────────────────────────────────────
# Max participants per media room (D-11).
PARTICIPANT_CAP=8
# Grace window (ms) before an empty room's router is reclaimed (D-12, 10000–30000).
RECONNECT_GRACE_MS=30000

# ──────────────────────────────────────────────────────────────
# OpenTelemetry (SFU-12)
# ──────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=sfu.sideby.me
# Cross-host OTLP endpoint — point at the trace.sideby.me box, NOT localhost (D-13).
# Telemetry is skipped gracefully when this is unset.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Optional comma-separated headers (e.g. Authorization=Bearer xxx) for cross-host
# OTLP transport auth.
OTEL_EXPORTER_OTLP_HEADERS=
# Deployment environment tag (development | staging | production).
DEPLOYMENT_ENVIRONMENT=development
